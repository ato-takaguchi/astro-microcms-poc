---
import { getAllContents, normalizeCaseItem } from '../lib/microcms.js';

let items = [];
let errorMessage = '';

try {
  const contents = await getAllContents();
  items = contents.map(normalizeCaseItem).filter((item) => item.id);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : String(error);
}
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>microCMS POC</title>
</head>
<body>
  <main>
    <h1>microCMS POC</h1>
    {errorMessage ? (
      <p>{errorMessage}</p>
    ) : (
      <ul>
        {items.map((item) => (
          <li><a href={`/cases/elevator/gallery/${item.id}.html`}>{item.title}</a></li>
        ))}
      </ul>
    )}
  </main>
</body>
</html>
