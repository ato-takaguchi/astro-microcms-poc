---
const ASSET_BASE = 'https://www.mebs.co.jp';

export async function getStaticPaths() {
  const serviceDomain = import.meta.env.MICROCMS_SERVICE_DOMAIN;
  const apiKey = import.meta.env.MICROCMS_API_KEY;
  const endpoint = import.meta.env.MICROCMS_ENDPOINT || 'case-gallery';

  if (!serviceDomain || !apiKey) {
    throw new Error('MICROCMS_SERVICE_DOMAIN または MICROCMS_API_KEY が未設定です。');
  }

  const url = `https://${serviceDomain}.microcms.io/api/v1/${endpoint}`;
  const res = await fetch(url, {
    headers: {
      'X-MICROCMS-API-KEY': apiKey,
    },
  });

  if (!res.ok) {
    const text = await res.text();
    throw new Error(`microCMS API error: ${res.status} ${res.statusText} ${text}`);
  }

  const data = await res.json();

  return data.contents.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;

function absolutize(html = '') {
  return html
    .replace(/src="\/(?!\/)/g, `src="${ASSET_BASE}/`)
    .replace(/href="\/(?!\/)/g, `href="${ASSET_BASE}/`)
    .replace(/src='\/(?!\/)/g, `src='${ASSET_BASE}/`)
    .replace(/href='\/(?!\/)/g, `href='${ASSET_BASE}/`);
}

const body = absolutize(item.body ?? '');
const pageTitle = item.title ?? '導入事例';
