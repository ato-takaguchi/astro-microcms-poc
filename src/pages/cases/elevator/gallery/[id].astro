---
import { getContentById, normalizeCaseItem } from '../../../../lib/microcms.js';

export const prerender = false;

const ASSET_BASE = 'https://www.mebs.co.jp';

function absolutize(html = '') {
  return html
    .replace(/src="\/(?!\/)/g, `src="${ASSET_BASE}/`)
    .replace(/href="\/(?!\/)/g, `href="${ASSET_BASE}/`)
    .replace(/src='\/(?!\/)/g, `src='${ASSET_BASE}/`)
    .replace(/href='\/(?!\/)/g, `href='${ASSET_BASE}/`);
}

const routeId = Astro.params.id ?? '';
const contentId = routeId.replace(/\.html$/i, '');
const draftKey = Astro.url.searchParams.get('draftKey') ?? undefined;

const rawItem = await getContentById(contentId, { draftKey });
const page = rawItem ? normalizeCaseItem(rawItem) : null;

if (!page) {
  Astro.response.status = 404;
}

const body = absolutize(page?.body ?? '');
const pageTitle = page?.title ?? '導入事例が見つかりません';
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  {page && <meta name="description" content={page.description} />}
  {page && <link rel="canonical" href={page.canonicalUrl} />}
  <link rel="stylesheet" href={`${ASSET_BASE}/assets/css/style.css?2025030801`} type="text/css" />
</head>

<body>
  <div id="wrapper" class="g-wrapper">
    <main class="g-pageMain" role="main">
      {page ? (
        <>
          <div class="c-breadcrumb">
            <div class="c-breadcrumb_inner">
              <ul class="c-breadcrumb_list">
                <li class="c-breadcrumb_listItem">
                  <div class="c-breadcrumb_listItemInner">
                    <a class="c-breadcrumb_listLink" href={`${ASSET_BASE}/`}>トップページ</a>
                  </div>
                </li>
                <li class="c-breadcrumb_listItem">
                  <div class="c-breadcrumb_listItemInner">
                    <a class="c-breadcrumb_listLink" href={`${ASSET_BASE}/cases/`}>導入事例</a>
                  </div>
                </li>
                <li class="c-breadcrumb_listItem">
                  <div class="c-breadcrumb_listItemInner">
                    <span class="c-breadcrumb_listText">{page.title}</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <div class="l-globalContainer">
            <div class="c-titleHeadingCases c-titleHeadingCases-gallery">
              <div class="c-titleHeadingCases_inner">
                <div class="c-titleHeadingCases_block">
                  <h1 class="c-titleHeadingCases_main">{page.title}</h1>
                </div>
              </div>
            </div>

            <div class="l-section-editarea">
              <div class="l-container">
                <div class="c-editarea" set:html={body}></div>
              </div>
            </div>
          </div>
        </>
      ) : (
        <div class="l-globalContainer">
          <div class="l-container" style="padding: 4rem 1rem;">
            <h1>404</h1>
            <p>指定された導入事例は見つかりませんでした。</p>
          </div>
        </div>
      )}
    </main>
  </div>

  <script is:inline src={`${ASSET_BASE}/assets/js/nav.js`}></script>
  <script is:inline src={`${ASSET_BASE}/assets/js/main.js`}></script>
</body>
</html>
