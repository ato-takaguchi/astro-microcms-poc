---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllContents, normalizeCaseItem } from '../../lib/microcms.js';

export const prerender = true;

const ASSET_BASE = 'https://www.mebs.co.jp';

let items = [];
let errorMessage = '';

try {
  const contents = await getAllContents();
  items = contents.map(normalizeCaseItem).filter((item) => item.id);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : String(error);
}
---

<BaseLayout title="導入事例 | 三菱電機ビルソリューションズ">

  <div class="c-breadcrumb">
    <div class="c-breadcrumb_inner">
      <ul class="c-breadcrumb_list">
        <li class="c-breadcrumb_listItem">
          <div class="c-breadcrumb_listItemInner">
            <a class="c-breadcrumb_listLink" href={`${ASSET_BASE}/`}>トップページ</a>
          </div>
        </li>
        <li class="c-breadcrumb_listItem">
          <div class="c-breadcrumb_listItemInner">
            <span class="c-breadcrumb_listText">導入事例</span>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <div class="l-globalContainer">
    <main class="g-pageMain" role="main">

      <div class="c-titleHeadingCases">
        <div class="c-titleHeadingCases_inner">
          <div class="c-titleHeadingCases_spBg">
            <div class="c-titleHeadingCases_block">
              <h1 class="c-titleHeadingCases_main">導入事例</h1>
            </div>
          </div>
        </div>
      </div>

      {errorMessage ? (
        <section class="l-section">
          <div class="l-container">
            <p>{errorMessage}</p>
          </div>
        </section>
      ) : (
        <section class="l-section">
          <div class="l-container">
            <div class="l-threeColumn-line">
              {items.map((item) => (
                <div class="l-threeColumn-line_item c-casesCard">
                  <a class="c-casesCard_link" href={`${import.meta.env.BASE_URL}/cases/elevator/gallery/${item.id}.html`}>
                    {item.listImage && (
                      <div class="c-casesCard_linkImage">
                        <figure class="c-casesCard_linkImageSrc">
                          <img src={item.listImage} alt={item.listImageAlt || item.title} width="380" height="214" />
                        </figure>
                      </div>
                    )}
                    <div class="c-casesCard_linkContents">
                      <div class="c-casesCard_linkContentsInner">
                        {item.productTags.length > 0 && (
                          <ul class="c-list-tag">
                            {item.productTags.map((tag) => (
                              <li class="c-list-tag_item">
                                <div class="c-tag">
                                  <span class="c-tag_text c-tag_text-fsXSmall">{tag}</span>
                                </div>
                              </li>
                            ))}
                          </ul>
                        )}
                        <p class="c-casesCard_linkTitle">{item.title}</p>
                      </div>
                      <div class="c-casesCard_linkArrow">
                        <span class="material-icons-outlined material-icons-outlined-arrow-forward">&nbsp;</span>
                      </div>
                    </div>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

    </main>
  </div>

</BaseLayout>
